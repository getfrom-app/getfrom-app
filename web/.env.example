# Google Sign-In (web client ID — crear en console.cloud.google.com)
# Proyecto: from-app / APIs & Services / Credentials / Create OAuth client ID (Web)
# Authorized origins: https://getfrom.app, http://localhost:5173
VITE_GOOGLE_WEB_CLIENT_ID=

# Apple Sign-In (Services ID — crear en developer.apple.com)
# Identifiers / + / Services IDs → e.g. "app.getfrom.web"
# Configure: Return URLs = https://getfrom.app/app/
VITE_APPLE_WEB_SERVICE_ID=
VITE_APPLE_REDIRECT_URI=https://getfrom.app/app/
